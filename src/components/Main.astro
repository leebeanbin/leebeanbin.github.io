---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  pageTitle: string | [string, string];
  pageTitleEn?: string;
  pageDesc?: string;
  pageDescEn?: string;
  class?: string;
};

const { pageTitle, pageTitleEn, pageDesc, pageDescEn, class: className } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const backUrl = config.features.showBackButton
  ? Astro.url.pathname
  : getRelativeLocaleUrl(locale, "");
---

<main
  data-backUrl={backUrl}
  id="main-content"
  class:list={["app-layout pb-4", className]}
>
  <h1 class="text-2xl font-semibold sm:text-3xl">
    {pageTitleEn ? (
      <>
        <span class="lang-ko">{pageTitle}</span>
        <span class="lang-en">{pageTitleEn}</span>
      </>
    ) : pageTitle}
  </h1>
  {(pageDesc || pageDescEn) && (
    <p class="mt-2 mb-6 italic">
      {pageDescEn ? (
        <>
          <span class="lang-ko">{pageDesc}</span>
          <span class="lang-en">{pageDescEn}</span>
        </>
      ) : pageDesc}
    </p>
  )}
  <slot />
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  });
</script>
