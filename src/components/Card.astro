---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { getPostUrl } from "@/utils/getPostPaths";
import { toTransitionName } from "@/utils/toTransitionName";
import { getPostCategory } from "@/utils/getPostCategory";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, body, filePath } = Astro.props;

const { title, description, ogImage, tags, featured, ...props } = data;
const postUrl = getPostUrl(id, filePath, Astro.currentLocale);
const category = getPostCategory(id);

const hasImage = !!ogImage;
const imgSrc = typeof ogImage === "string" ? ogImage : ogImage?.src;

const wordCount = body ? body.split(/\s+/).filter(Boolean).length : 0;
const readingMins = Math.max(1, Math.ceil(wordCount / 200));
---

<li class="post-card group relative" data-title={title} data-desc={description} data-url={postUrl} data-img={imgSrc ?? ""} data-tags={JSON.stringify(tags)}>
  <a
    href={postUrl}
    class="card-link flex gap-4 rounded-xl border border-border p-4 transition-colors duration-200
           hover:border-accent/40
           focus-visible:no-underline focus-visible:outline-2 focus-visible:outline-dashed focus-visible:outline-accent"
  >
    <!-- Featured indicator -->
    {featured && (
      <span
        class="absolute -top-px left-4 right-4 h-px"
        style="background: linear-gradient(90deg, transparent, var(--accent), transparent);"
        aria-hidden="true"
      ></span>
    )}

    <!-- 썸네일 -->
    {hasImage && (
      <div class="hidden sm:block shrink-0 w-24 h-16 overflow-hidden rounded-lg bg-muted">
        {typeof ogImage === "string" ? (
          <img src={ogImage} alt={title} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
        ) : (
          <Image src={ogImage} alt={title} width={96} height={64} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
        )}
      </div>
    )}

    <!-- 텍스트 -->
    <div class="flex flex-col justify-between min-w-0 flex-1 gap-2">
      <div>
        <Heading
          transition:name={toTransitionName(title)}
          class="text-foreground text-[15px] font-semibold leading-snug line-clamp-2"
        >
          {title}
        </Heading>
        <p class="mt-1 text-sm text-muted-foreground line-clamp-2 leading-relaxed">{description}</p>
      </div>

      <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
        <Datetime {...props} class="text-xs" />
        <span class="text-xs text-muted-foreground/60 font-mono before:content-['·'] before:mr-2">{readingMins} min read</span>
        {category && (
          <span class="rounded-md border border-border px-1.5 py-0.5 font-mono text-xs text-muted-foreground">
            {category}
          </span>
        )}
        {tags.slice(0, 3).map(tag => (
          <span class="font-mono text-xs text-muted-foreground/60">
            #{tag}
          </span>
        ))}
      </div>
    </div>
  </a>

  <!-- 호버 툴팁 -->
  <div
    class="post-preview pointer-events-none absolute left-0 top-full z-50 mt-1 w-72 hidden sm:block
           rounded-xl border border-border bg-background p-4
           shadow-[0_8px_30px_rgba(0,0,0,0.10)] dark:shadow-[0_8px_30px_rgba(0,0,0,0.5)]
           opacity-0 translate-y-1 transition-all duration-150"
    aria-hidden="true"
  >
    <!-- 말풍선 화살표 -->
    <span class="absolute -top-1.5 left-5 size-3 border-t border-l border-border rotate-45 bg-background/95 block" aria-hidden="true"></span>

    {hasImage && (
      <div class="mb-3 h-32 w-full overflow-hidden rounded-lg bg-muted">
        {typeof ogImage === "string" ? (
          <img src={ogImage} alt={title} class="w-full h-full object-cover" loading="lazy" />
        ) : (
          <Image src={ogImage} alt={title} width={272} height={128} class="w-full h-full object-cover" loading="lazy" />
        )}
      </div>
    )}
    <p class="font-semibold text-sm leading-snug line-clamp-2 mb-1">{title}</p>
    <p class="text-xs text-muted-foreground line-clamp-3 leading-relaxed">{description}</p>
    {tags.length > 0 && (
      <div class="mt-2.5 flex flex-wrap gap-1">
        {tags.slice(0, 4).map(tag => (
          <span class="font-mono text-xs text-muted-foreground/60">#{tag}</span>
        ))}
      </div>
    )}
  </div>
</li>

<script>
  function initPreviews() {
    document.querySelectorAll<HTMLElement>(".post-card").forEach(card => {
      const preview = card.querySelector<HTMLElement>(".post-preview");
      if (!preview) return;

      let timer: ReturnType<typeof setTimeout>;

      const show = () => {
        clearTimeout(timer);
        timer = setTimeout(() => {
          // Overflow guard: flip to right if near left edge
          const rect = card.getBoundingClientRect();
          if (rect.left < 20) {
            preview.style.left = "auto";
            preview.style.right = "0";
          } else {
            preview.style.left = "0";
            preview.style.right = "auto";
          }
          preview.classList.remove("hidden");
          requestAnimationFrame(() => {
            preview.style.opacity = "1";
            preview.style.transform = "translateY(0)";
          });
        }, 400);
      };

      const hide = () => {
        clearTimeout(timer);
        preview.style.opacity = "0";
        preview.style.transform = "translateY(4px)";
        setTimeout(() => preview.classList.add("hidden"), 150);
      };

      card.addEventListener("mouseenter", show);
      card.addEventListener("mouseleave", hide);
      card.addEventListener("focusin", show);
      card.addEventListener("focusout", hide);
    });
  }

  initPreviews();
  document.addEventListener("astro:after-swap", initPreviews);
</script>

<style>
  .post-preview {
    transform: translateY(4px);
  }
  @media (prefers-reduced-motion: reduce) {
    .card-link:hover { transform: none; }
    .post-preview { transition: none; }
  }
</style>
