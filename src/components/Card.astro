---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { getPostUrl } from "@/utils/getPostPaths";
import { toTransitionName } from "@/utils/toTransitionName";
import { getPostCategory } from "@/utils/getPostCategory";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ogImage, tags, ...props } = data;
const postUrl = getPostUrl(id, filePath, Astro.currentLocale);
const category = getPostCategory(id);  // 폴더 이름 → 카테고리

const hasImage = !!ogImage;
const imgSrc = typeof ogImage === "string" ? ogImage : ogImage?.src;
---

<li
  class="post-card group my-4 relative"
  data-title={title}
  data-desc={description}
  data-url={postUrl}
  data-img={imgSrc ?? ""}
  data-tags={JSON.stringify(tags)}
>
  <a
    href={postUrl}
    class:list={[
      "flex gap-4 rounded-xl border border-border hover:border-accent",
      "p-4 transition-all hover:shadow-md",
      "focus-visible:no-underline focus-visible:outline-2 focus-visible:outline-dashed focus-visible:outline-accent",
    ]}
  >
    <!-- 썸네일 -->
    {hasImage && (
      <div class="hidden sm:block shrink-0 w-28 h-20 overflow-hidden rounded-lg">
        {typeof ogImage === "string" ? (
          <img
            src={ogImage}
            alt={title}
            class="w-full h-full object-cover transition-transform group-hover:scale-105"
            loading="lazy"
          />
        ) : (
          <Image
            src={ogImage}
            alt={title}
            width={112}
            height={80}
            class="w-full h-full object-cover transition-transform group-hover:scale-105"
            loading="lazy"
          />
        )}
      </div>
    )}

    <!-- 텍스트 내용 -->
    <div class="flex flex-col justify-between min-w-0 flex-1">
      <div>
        <Heading
          transition:name={toTransitionName(title)}
          class:list={[
            "text-accent text-base font-medium leading-snug",
            "decoration-dashed underline-offset-4 group-hover:underline",
            "line-clamp-2",
          ]}
        >
          {title}
        </Heading>
        <p class="mt-1.5 text-sm text-muted-foreground line-clamp-2">{description}</p>
      </div>

      <div class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1">
        <Datetime {...props} class="text-xs" />
        {category && (
          <span class="bg-foreground/8 border border-border rounded px-1.5 py-0.5 font-mono text-xs text-muted-foreground">
            {category}
          </span>
        )}
        {tags.slice(0, 3).map(tag => (
          <span class="bg-accent/10 text-accent rounded px-1.5 py-0.5 font-mono text-xs">
            #{tag}
          </span>
        ))}
      </div>
    </div>
  </a>

  <!-- 호버 미리보기 툴팁 -->
  <div
    class="post-preview pointer-events-none absolute left-0 top-full z-50 mt-2 hidden w-72
           rounded-xl border border-border bg-background p-4 shadow-lg
           opacity-0 transition-opacity sm:block"
    aria-hidden="true"
  >
    {hasImage && (
      <div class="mb-3 h-36 w-full overflow-hidden rounded-lg">
        {typeof ogImage === "string" ? (
          <img src={ogImage} alt={title} class="w-full h-full object-cover" loading="lazy" />
        ) : (
          <Image
            src={ogImage}
            alt={title}
            width={288}
            height={144}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        )}
      </div>
    )}
    <p class="mb-1 font-semibold text-sm leading-snug line-clamp-2">{title}</p>
    <p class="text-xs text-muted-foreground line-clamp-3">{description}</p>
    {tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1">
        {tags.slice(0, 4).map(tag => (
          <span class="bg-accent/10 text-accent rounded px-1.5 py-0.5 font-mono text-xs">#{tag}</span>
        ))}
      </div>
    )}
  </div>
</li>

<script>
  function initPreviews() {
    document.querySelectorAll<HTMLElement>(".post-card").forEach(card => {
      const preview = card.querySelector<HTMLElement>(".post-preview");
      if (!preview) return;

      let timer: ReturnType<typeof setTimeout>;

      card.addEventListener("mouseenter", () => {
        clearTimeout(timer);
        timer = setTimeout(() => {
          preview.classList.remove("hidden");
          requestAnimationFrame(() => {
            preview.style.opacity = "1";
          });
        }, 350);
      });

      card.addEventListener("mouseleave", () => {
        clearTimeout(timer);
        preview.style.opacity = "0";
        setTimeout(() => preview.classList.add("hidden"), 150);
      });
    });
  }

  initPreviews();
  document.addEventListener("astro:after-swap", initPreviews);
</script>
