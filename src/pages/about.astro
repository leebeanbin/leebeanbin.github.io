---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { siteContent } from "@/data/site";
import { resume } from "@/data/resume";
import { TECH_COLORS } from "@/data/techColors";

const { about, hero, techStack } = siteContent;
const { name, contact } = resume;
---

<Layout
  title={`소개 | About | ${config.site.title}`}
  description={`${name.ko} (${name.en}) — AI/Backend Engineer`}
>
  <Header />
  <main id="main-content" class="app-layout py-12 sm:py-16">

    <!-- 헤더 -->
    <div class="border-b border-border pb-10 mb-10">
      <p class="text-xs font-mono text-muted-foreground uppercase tracking-widest mb-3">About</p>
      <div class="flex flex-wrap items-baseline gap-3 mb-1">
        <h1 class="text-3xl sm:text-4xl font-bold">
          <span class="lang-ko">{name.ko}</span>
          <span class="lang-en">{name.en}</span>
        </h1>
        <span class="text-xl text-muted-foreground font-light">
          <span class="lang-ko">{name.en}</span>
          <span class="lang-en">{name.ko}</span>
        </span>
      </div>
      <p class="text-accent font-mono text-sm mt-1">{hero.role}</p>
    </div>

    <!-- 소개 문단 -->
    <section class="mb-12 max-w-2xl space-y-4">
      {about.ko.map((p, i) => (
        <>
          <p class="lang-ko text-base leading-relaxed text-muted-foreground">{p}</p>
          <p class="lang-en text-base leading-relaxed text-muted-foreground">{about.en[i]}</p>
        </>
      ))}
    </section>

    <!-- GitHub 잔디 -->
    <section class="mb-12">
      <h2 class="text-xs font-mono uppercase tracking-widest text-muted-foreground mb-4">
        <span class="lang-ko">GitHub 기여</span>
        <span class="lang-en">GitHub Contributions</span>
      </h2>
      <div class="overflow-x-auto rounded-xl border border-border p-4">
        <!-- Light mode -->
        <img
          src="https://ghchart.rshah.org/0284c7/leebeanbin"
          alt="GitHub contribution graph"
          class="w-full dark:hidden"
          loading="lazy"
        />
        <!-- Dark mode -->
        <img
          src="https://ghchart.rshah.org/58a6ff/leebeanbin"
          alt="GitHub contribution graph"
          class="w-full hidden dark:block"
          loading="lazy"
        />
      </div>
      <a href={contact.github} target="_blank" rel="noopener"
         class="inline-flex items-center gap-1 mt-2 text-xs text-muted-foreground hover:text-accent transition-colors">
        <svg class="size-3" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        github.com/leebeanbin
      </a>
    </section>

    <!-- 기술 스택 (칩 클라우드 — 간략버전) -->
    <section class="mb-12">
      <h2 class="text-xs font-mono uppercase tracking-widest text-muted-foreground mb-4">
        <span class="lang-ko">주요 기술</span>
        <span class="lang-en">Tech Stack</span>
      </h2>
      <div class="flex flex-wrap gap-2">
        {techStack.map(tech => {
          const color = TECH_COLORS[tech];
          return (
            <span
              class="tech-chip border rounded-full px-3 py-1 text-sm font-mono cursor-default transition-all"
              style={color ? `--chip-color:${color}` : ""}
            >
              {tech}
            </span>
          );
        })}
      </div>
      <p class="mt-3 text-xs text-muted-foreground">
        <span class="lang-ko">상세 기술 스택과 경력은</span>
        <span class="lang-en">Full skill breakdown and work history on</span>
        <a href="/resume" class="text-accent hover:underline ml-1">
          <span class="lang-ko">이력서 페이지</span>
          <span class="lang-en">Resume</span>
        </a>
        <span class="lang-ko">에서 확인할 수 있습니다.</span>
        <span class="lang-en">.</span>
      </p>
    </section>

    <!-- 연락처 -->
    <section>
      <h2 class="text-xs font-mono uppercase tracking-widest text-muted-foreground mb-4">Contact</h2>
      <div class="flex flex-wrap gap-3">
        <a href={`mailto:${contact.email}`}
           class="flex items-center gap-2 border border-border rounded-lg px-4 py-2.5 text-sm hover:border-accent hover:text-accent transition-colors">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          {contact.email}
        </a>
        <a href={contact.github} target="_blank" rel="noopener"
           class="flex items-center gap-2 border border-border rounded-lg px-4 py-2.5 text-sm hover:border-accent hover:text-accent transition-colors">
          <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
        <a href="/resume"
           class="flex items-center gap-2 border border-border rounded-lg px-4 py-2.5 text-sm hover:border-accent hover:text-accent transition-colors">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <span class="lang-ko">이력서</span>
          <span class="lang-en">Resume</span>
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .tech-chip {
    background: color-mix(in srgb, var(--chip-color, #6366F1) 10%, transparent);
    color: var(--chip-color, #6366F1);
    border-color: color-mix(in srgb, var(--chip-color, #6366F1) 30%, transparent);
  }
  .tech-chip:hover {
    background: color-mix(in srgb, var(--chip-color, #6366F1) 20%, transparent);
    border-color: var(--chip-color, #6366F1);
    transform: translateY(-1px);
  }
</style>
