---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { siteContent } from "@/data/site";
import { resume } from "@/data/resume";
import GitHubChart from "@/components/GitHubChart.astro";
const { about, hero } = siteContent;
const { name, contact } = resume;
---

<Layout
  title={`소개 | About | ${config.site.title}`}
  description={`${name.ko} (${name.en}) — AI/Backend Engineer`}
>
  <Header />
  <main id="main-content" class="app-layout py-12 sm:py-16">

    <!-- 헤더 — 이름 + 아이콘 링크 -->
    <div class="border-b border-border pb-10 mb-10 animate-fade-in-up">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-mono text-muted-foreground uppercase tracking-widest mb-3">About</p>
          <div class="flex flex-wrap items-baseline gap-3 mb-1">
            <h1 class="font-bold" style="font-size: var(--text-fluid-3xl)">
              <span class="lang-ko">{name.ko}</span>
              <span class="lang-en">{name.en}</span>
            </h1>
            <span class="text-muted-foreground font-light" style="font-size: var(--text-fluid-xl)">
              <span class="lang-ko">{name.en}</span>
              <span class="lang-en">{name.ko}</span>
            </span>
          </div>
          <p class="text-accent font-mono text-sm mt-1">{hero.role}</p>
        </div>

        <!-- 빠른 링크 아이콘 그룹 -->
        <div class="flex items-center gap-1 mt-1 shrink-0">
          <!-- 이력서 -->
          <a href="/resume" title="이력서 / Resume"
             class="btn-ghost size-9 rounded-lg" aria-label="이력서">
            <svg class="size-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
            </svg>
          </a>
          <!-- 이메일 -->
          <a href={`mailto:${contact.email}`} title={contact.email}
             class="btn-ghost size-9 rounded-lg" aria-label="이메일">
            <svg class="size-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
          </a>
          <!-- GitHub -->
          <a href={contact.github} target="_blank" rel="noopener" title="GitHub"
             class="btn-ghost size-9 rounded-lg" aria-label="GitHub">
            <svg class="size-[18px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
          {contact.linkedin && (
            <a href={contact.linkedin} target="_blank" rel="noopener" title="LinkedIn"
               class="btn-ghost size-9 rounded-lg" aria-label="LinkedIn">
              <svg class="size-[18px]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- 통계 -->
    <div class="grid grid-cols-3 gap-3 sm:gap-4 mb-12 reveal">
      <div class="stat-card border border-border rounded-xl p-4 text-center hover:border-accent transition-colors">
        <p class="text-2xl font-bold text-accent">3+</p>
        <p class="text-xs text-muted-foreground mt-1 font-mono">
          <span class="lang-ko">경력 회사</span>
          <span class="lang-en">Companies</span>
        </p>
      </div>
      <div class="stat-card border border-border rounded-xl p-4 text-center hover:border-accent transition-colors">
        <p class="text-2xl font-bold text-accent">10+</p>
        <p class="text-xs text-muted-foreground mt-1 font-mono">
          <span class="lang-ko">공개 레포</span>
          <span class="lang-en">Public Repos</span>
        </p>
      </div>
      <div class="stat-card border border-border rounded-xl p-4 text-center hover:border-accent transition-colors">
        <p class="text-2xl font-bold text-accent">2+</p>
        <p class="text-xs text-muted-foreground mt-1 font-mono">
          <span class="lang-ko">오픈소스</span>
          <span class="lang-en">OSS</span>
        </p>
      </div>
    </div>

    <!-- 소개 문단 -->
    <div class="mb-14 max-w-2xl space-y-4 reveal reveal-delay-1">
      {about.ko.map((p, i) => (
        <>
          <p class="lang-ko text-base leading-relaxed text-muted-foreground">{p}</p>
          <p class="lang-en text-base leading-relaxed text-muted-foreground">{about.en[i]}</p>
        </>
      ))}
    </div>

    <!-- GitHub 잔디 -->
    <div class="mb-14 reveal reveal-delay-2 overflow-x-auto rounded-xl border border-border p-4 bg-muted/30">
      <GitHubChart />
    </div>

  </main>
  <Footer />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": name.en,
  "alternateName": name.ko,
  "jobTitle": "AI / Backend Engineer",
  "email": `mailto:${contact.email}`,
  "url": contact.blog,
  "sameAs": [contact.github, contact.linkedin].filter(Boolean),
})} />

<style>
  .stat-card {
    background: var(--background);
  }
</style>
