---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { resume } from "@/data/resume";
import { TECH_COLORS } from "@/data/techColors";

const { name, title, photo, summary, summaryEn, contact, experience, education, skills, projects, certifications, awards } = resume;

const CATEGORY_COLORS: Record<string, string> = {
  "Languages":        "#3178C6",
  "Backend":          "#6DB33F",
  "AI / ML":          "#7C3AED",
  "Database & Infra": "#F59E0B",
  "Frontend":         "#06B6D4",
};

function chipStyle(tech: string): string {
  const color = TECH_COLORS[tech];
  return color ? `--chip-color:${color}` : "";
}
---

<Layout
  title={`${name.en} — Resume | ${config.site.title}`}
  description={`${name.en} — ${title.en}`}
>
  <Header />

  <main id="main-content" class="app-layout py-10 sm:py-14 print:py-0">

    <!-- 브레드크럼 (인쇄 시 숨김) -->
    <p class="text-xs text-muted-foreground mb-8 print:hidden">
      <a href="/about" class="hover:text-accent transition-colors">
        <span class="lang-ko">소개</span><span class="lang-en">About</span>
      </a>
      <span class="mx-2 opacity-50">›</span>
      <span class="lang-ko">이력서</span><span class="lang-en">Resume</span>
    </p>

    <!-- ══ HEADER — 이름 + 사진 ═══════════════════════════════════════════ -->
    <section class="resume-header mb-8 pb-8 border-b border-border flex gap-8 items-start justify-between">
      <!-- 왼쪽: 이름 / 직책 / 연락처 -->
      <div class="flex-1 min-w-0">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-1">
          <span class="lang-ko">{name.ko}</span>
          <span class="lang-en">{name.en}</span>
        </h1>
        <p class="text-accent font-semibold text-lg mb-4">
          <span class="lang-ko">{title.ko}</span>
          <span class="lang-en">{title.en}</span>
        </p>

        <!-- 연락처 그리드 -->
        <div class="flex flex-wrap gap-x-5 gap-y-1.5 text-sm text-muted-foreground">
          <a href={`mailto:${contact.email}`} class="resume-contact-link">
            <svg class="size-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            {contact.email}
          </a>
          <a href={contact.github} target="_blank" rel="noopener" class="resume-contact-link">
            <svg class="size-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            github.com/leebeanbin
          </a>
          {contact.linkedin && (
            <a href={contact.linkedin} target="_blank" rel="noopener" class="resume-contact-link">
              <svg class="size-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          )}
          {contact.blog && (
            <a href={contact.blog} class="resume-contact-link">
              <svg class="size-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
              </svg>
              leebeanbin.github.io
            </a>
          )}
          {contact.location && (
            <span class="resume-contact-link pointer-events-none">
              <svg class="size-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              {contact.location}
            </span>
          )}
          {contact.phone && (
            <a href={`tel:${contact.phone}`} class="resume-contact-link">
              <svg class="size-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {contact.phone}
            </a>
          )}
        </div>
      </div>

      <!-- 오른쪽: 증명사진 -->
      {photo && (
        <div class="shrink-0 hidden sm:block print:block">
          <img
            src={photo}
            alt={`${name.en} profile`}
            class="w-28 h-36 object-cover rounded-lg border border-border shadow-sm"
          />
        </div>
      )}
    </section>

    <!-- ══ SUMMARY ════════════════════════════════════════════════════════ -->
    <section class="mb-8">
      <h2 class="resume-section-title">
        <span class="lang-ko">요약</span>
        <span class="lang-en">Summary</span>
      </h2>
      <p class="text-sm sm:text-base leading-relaxed text-muted-foreground max-w-3xl whitespace-pre-line">
        {summaryEn ? (
          <>
            <span class="lang-ko">{summary}</span>
            <span class="lang-en">{summaryEn}</span>
          </>
        ) : summary}
      </p>
    </section>

    <!-- ══ EXPERIENCE ════════════════════════════════════════════════════ -->
    {experience.length > 0 && (
      <section class="mb-8">
        <h2 class="resume-section-title">
          <span class="lang-ko">경력</span>
          <span class="lang-en">Experience</span>
        </h2>
        <div class="space-y-7">
          {experience.map(exp => (
            <div class="relative pl-4 border-l-2 border-border hover:border-accent transition-colors group">
              <!-- 타임라인 점 -->
              <div class="absolute -left-[5px] top-1.5 size-2 rounded-full bg-border group-hover:bg-accent transition-colors"></div>

              <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-1 mb-2">
                <div>
                  <span class="font-bold text-base">{exp.company}</span>
                  <span class="mx-2 text-border">·</span>
                  <span class="font-semibold text-accent">
                    {exp.roleEn ? (
                      <>
                        <span class="lang-ko">{exp.role}</span>
                        <span class="lang-en">{exp.roleEn}</span>
                      </>
                    ) : exp.role}
                  </span>
                  {exp.location && (
                    <span class="ml-2 text-xs text-muted-foreground font-mono">{exp.location}</span>
                  )}
                </div>
                <span class="text-xs text-muted-foreground font-mono shrink-0 mt-0.5">{exp.period}</span>
              </div>

              {(exp.description || exp.descriptionEn) && (
                <p class="text-sm text-muted-foreground italic mb-2">
                  {exp.descriptionEn ? (
                    <>
                      <span class="lang-ko">{exp.description}</span>
                      <span class="lang-en">{exp.descriptionEn}</span>
                    </>
                  ) : exp.description}
                </p>
              )}

              <ul class="space-y-1.5 mb-3">
                {exp.bulletsEn ? (
                  exp.bullets.map((b, i) => (
                    <li class="text-sm flex gap-2.5">
                      <span class="text-accent shrink-0 mt-0.5 select-none">▸</span>
                      <span>
                        <span class="lang-ko">{b}</span>
                        <span class="lang-en">{exp.bulletsEn![i] ?? b}</span>
                      </span>
                    </li>
                  ))
                ) : (
                  exp.bullets.map(b => (
                    <li class="text-sm flex gap-2.5">
                      <span class="text-accent shrink-0 mt-0.5 select-none">▸</span>
                      <span>{b}</span>
                    </li>
                  ))
                )}
              </ul>

              <div class="flex flex-wrap gap-1.5">
                {exp.tags.map(tag => (
                  <span class="tech-chip border rounded-full px-2 py-0.5 font-mono text-xs transition-all" style={chipStyle(tag)}>
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ══ SKILLS ════════════════════════════════════════════════════════ -->
    <section class="mb-8">
      <h2 class="resume-section-title">
        <span class="lang-ko">기술 스택</span>
        <span class="lang-en">Technical Skills</span>
      </h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {skills.map(group => {
          const catColor = CATEGORY_COLORS[group.category] ?? "#6366F1";
          return (
            <div
              class="rounded-xl border border-border p-4 transition-shadow hover:shadow-sm"
              style={`border-left: 3px solid ${catColor}`}
            >
              <p class="text-xs font-bold uppercase tracking-widest mb-2.5" style={`color:${catColor}`}>
                {group.category}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {group.items.map(item => (
                  <span class="tech-chip border rounded-full px-2.5 py-0.5 text-xs font-mono cursor-default transition-all" style={chipStyle(item)}>
                    {item}
                  </span>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ══ PROJECTS ══════════════════════════════════════════════════════ -->
    {projects.length > 0 && (
      <section class="mb-8">
        <h2 class="resume-section-title">
          <span class="lang-ko">프로젝트</span>
          <span class="lang-en">Projects</span>
        </h2>
        <div class="space-y-4">
          {projects.map(p => (
            <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4">
              <a href={p.url} target="_blank" rel="noopener"
                 class="font-mono font-semibold text-sm hover:text-accent transition-colors shrink-0 w-36">
                {p.name} ↗
              </a>
              <div class="flex-1">
                <p class="text-sm text-muted-foreground mb-1.5">
                  {p.summaryEn ? (
                    <>
                      <span class="lang-ko">{p.summary}</span>
                      <span class="lang-en">{p.summaryEn}</span>
                    </>
                  ) : p.summary}
                </p>
                <div class="flex flex-wrap gap-1">
                  {p.tags.map(tag => (
                    <span class="tech-chip border rounded-full px-2 py-0.5 font-mono text-xs cursor-default transition-all" style={chipStyle(tag)}>
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="mt-3 text-xs text-muted-foreground">
          <a href="/projects" class="text-accent hover:underline">
            <span class="lang-ko">→ 전체 프로젝트 보기</span>
            <span class="lang-en">→ View all projects</span>
          </a>
        </p>
      </section>
    )}

    <!-- ══ EDUCATION ═════════════════════════════════════════════════════ -->
    {education.length > 0 && (
      <section class="mb-8">
        <h2 class="resume-section-title">
          <span class="lang-ko">학력</span>
          <span class="lang-en">Education</span>
        </h2>
        <div class="space-y-4">
          {education.map(edu => (
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <p class="font-bold text-sm">{edu.school}</p>
                <p class="text-sm text-muted-foreground">
                  {edu.majorEn ? (
                    <>
                      <span class="lang-ko">{edu.degree} · {edu.major}</span>
                      <span class="lang-en">{edu.degreeEn ?? edu.degree} · {edu.majorEn}</span>
                    </>
                  ) : `${edu.degree} · ${edu.major}`}
                  {edu.gpa && <span class="ml-2 text-xs font-mono">GPA {edu.gpa}</span>}
                </p>
                {(edu.note || edu.noteEn) && (
                  <p class="text-xs text-accent mt-0.5">
                    {edu.noteEn ? (
                      <>
                        <span class="lang-ko">{edu.note}</span>
                        <span class="lang-en">{edu.noteEn}</span>
                      </>
                    ) : edu.note}
                  </p>
                )}
              </div>
              <span class="text-xs text-muted-foreground font-mono shrink-0">{edu.period}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ══ CERTIFICATIONS / AWARDS ════════════════════════════════════════ -->
    {(certifications.length > 0 || awards.length > 0) && (
      <section class="mb-8">
        {certifications.length > 0 && (
          <div class="mb-5">
            <h2 class="resume-section-title">
              <span class="lang-ko">자격증</span>
              <span class="lang-en">Certifications</span>
            </h2>
            <ul class="space-y-1.5">
              {certifications.map(c => (
                <li class="flex flex-wrap items-baseline justify-between gap-2 text-sm">
                  <div>
                    <span class="font-medium">{c.name}</span>
                    <span class="text-muted-foreground ml-2 text-xs">{c.issuer}</span>
                  </div>
                  <span class="text-xs text-muted-foreground font-mono">{c.date}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        {awards.length > 0 && (
          <div>
            <h2 class="resume-section-title">
              <span class="lang-ko">수상</span>
              <span class="lang-en">Awards</span>
            </h2>
            <ul class="space-y-1.5">
              {awards.map(a => (
                <li class="flex flex-wrap items-baseline justify-between gap-2 text-sm">
                  <div>
                    <span class="font-medium">
                      {a.nameEn ? (
                        <>
                          <span class="lang-ko">{a.name}</span>
                          <span class="lang-en">{a.nameEn}</span>
                        </>
                      ) : a.name}
                    </span>
                    <span class="text-muted-foreground text-xs ml-2">{a.issuer}</span>
                    {(a.description || a.descriptionEn) && (
                      <span class="text-xs ml-2">
                        {a.descriptionEn ? (
                          <>
                            <span class="lang-ko">{a.description}</span>
                            <span class="lang-en">{a.descriptionEn}</span>
                          </>
                        ) : a.description}
                      </span>
                    )}
                  </div>
                  <span class="text-xs text-muted-foreground font-mono">{a.date}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )}

    <!-- 인쇄 버튼 -->
    <div class="mt-10 pt-6 border-t border-border flex items-center justify-between print:hidden">
      <p class="text-xs text-muted-foreground">
        <span class="lang-ko">PDF로 저장하려면 인쇄 → "PDF로 저장" 선택</span>
        <span class="lang-en">To save as PDF: Print → "Save as PDF"</span>
      </p>
      <button
        onclick="window.print()"
        class="flex items-center gap-2 border border-border hover:border-accent hover:text-accent text-sm px-4 py-2 rounded-lg transition-colors"
      >
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
        </svg>
        <span class="lang-ko">인쇄 / PDF</span>
        <span class="lang-en">Print / PDF</span>
      </button>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .resume-section-title {
    @apply text-xs font-bold uppercase tracking-widest text-accent mb-4 pb-1.5 border-b border-border;
  }
  .resume-contact-link {
    @apply flex items-center gap-1.5 hover:text-accent transition-colors;
  }

  /* 브랜드 컬러 칩 */
  .tech-chip {
    background: color-mix(in srgb, var(--chip-color, #6366F1) 10%, transparent);
    color: var(--chip-color, #6366F1);
    border-color: color-mix(in srgb, var(--chip-color, #6366F1) 30%, transparent);
  }
  .tech-chip:hover {
    background: color-mix(in srgb, var(--chip-color, #6366F1) 20%, transparent);
    border-color: var(--chip-color, #6366F1);
    transform: translateY(-1px);
  }

  /* 인쇄 최적화 */
  @media print {
    .print\:hidden { display: none !important; }
    .print\:block { display: block !important; }
    header, footer { display: none !important; }
    main { padding: 0 !important; max-width: 100% !important; }
    a { color: inherit !important; text-decoration: none !important; }
    .tech-chip {
      border: 1px solid currentColor !important;
      background: transparent !important;
    }
    .resume-header img { display: block !important; }
  }
</style>
