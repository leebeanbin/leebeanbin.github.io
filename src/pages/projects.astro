---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const projects = [
  {
    name: "beanllm",
    url: "https://github.com/leebeanbin/beanllm",
    desc: "멀티 프로바이더 LLM 통합 라이브러리 — OpenAI / Anthropic / Google / Ollama를 단일 인터페이스로 통합",
    tags: ["Python", "LLM", "OpenAI", "Anthropic", "Ollama"],
    featured: true,
  },
  {
    name: "umai",
    url: "https://github.com/leebeanbin/umai",
    desc: "채팅 · RAG · 워크플로우 · 파인튜닝 풀스택 AI 플랫폼",
    tags: ["Python", "FastAPI", "Next.js", "RAG", "LangChain"],
    featured: true,
  },
  {
    name: "mariabean",
    url: "https://github.com/leebeanbin/mariabean",
    desc: "DDD + Hexagonal Architecture 기반 공간예약 플랫폼 — 이벤트 소싱, Kafka, Elasticsearch 통합",
    tags: ["Spring Boot", "Kotlin", "Kafka", "Elasticsearch", "DDD"],
    featured: true,
  },
  {
    name: "beanCli",
    url: "https://github.com/leebeanbin/beanCli",
    desc: "TUI 기반 실시간 스트리밍 데이터 콘솔 — Kafka 토픽을 터미널에서 바로 시각화",
    tags: ["TypeScript", "Kafka", "PostgreSQL", "TUI"],
    featured: false,
  },
  {
    name: "message-broker-comparison-lab",
    url: "https://github.com/leebeanbin/message-broker-comparison-lab",
    desc: "Redis · RabbitMQ · Kafka 벤치마크 비교 분석 — Jupyter Notebook 18개 수록",
    tags: ["Python", "FastAPI", "Jupyter", "Kafka", "Redis", "RabbitMQ"],
    featured: false,
  },
  {
    name: "insightstock-ai-service",
    url: "https://github.com/leebeanbin/insightstock-ai-service",
    desc: "주식 데이터 기반 AI 분석 서비스 — GPT-4, Claude, Gemini 다중 모델 지원",
    tags: ["Python", "FastAPI", "LLM", "Finance"],
    featured: false,
  },
  {
    name: "WhereAmI",
    url: "https://github.com/leebeanbin/WhereAmI",
    desc: "실시간 위치 공유 PWA — 그룹 트래킹, 알림, 오프라인 지원",
    tags: ["TypeScript", "React", "PWA", "WebSocket"],
    featured: false,
  },
  {
    name: "mariabean-client",
    url: "https://github.com/leebeanbin/mariabean-client",
    desc: "mariabean 예약 플랫폼 프론트엔드 — Next.js 기반 관리자 + 사용자 UI",
    tags: ["Next.js", "React", "TypeScript"],
    featured: false,
  },
  {
    name: "dinobot",
    url: "https://github.com/leebeanbin/dinobot",
    desc: "Discord 밋업 알림 봇 — 개발자 커뮤니티 이벤트 자동 수집 및 공유",
    tags: ["TypeScript", "Discord.js", "Node.js"],
    featured: false,
  },
];

const featured = projects.filter(p => p.featured);
const others = projects.filter(p => !p.featured);
---

<Layout
  title={`Projects | ${config.site.title}`}
  description="leebeanbin의 포트폴리오 프로젝트 — AI, 백엔드, 풀스택 시스템"
>
  <Header />
  <Breadcrumb />
  <Main pageTitle="Projects" pageDesc="실제로 만든 시스템들 — 코드, 설계, 목적이 담겨 있습니다.">
    <section class="mb-10">
      <h2 class="mb-4 text-xl font-semibold">Featured</h2>
      <div class="grid gap-3 sm:gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          featured.map(p => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="border-border hover:border-accent group flex flex-col gap-2 rounded-lg border p-4 transition-colors hover:shadow-md"
            >
              <div class="flex items-center justify-between">
                <span class="font-mono text-sm font-semibold group-hover:text-accent">
                  {p.name}
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="size-4 opacity-50 group-hover:opacity-100"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
              </div>
              <p class="text-sm opacity-75">{p.desc}</p>
              <div class="mt-auto flex flex-wrap gap-1 pt-2">
                {p.tags.map(tag => (
                  <span class="bg-accent/10 text-accent rounded px-1.5 py-0.5 font-mono text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section>
      <h2 class="mb-4 text-xl font-semibold">More Projects</h2>
      <div class="grid gap-3 sm:gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          others.map(p => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="border-border hover:border-accent group flex flex-col gap-2 rounded-lg border p-4 transition-colors hover:shadow-md"
            >
              <div class="flex items-center justify-between">
                <span class="font-mono text-sm font-semibold group-hover:text-accent">
                  {p.name}
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="size-4 opacity-50 group-hover:opacity-100"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
              </div>
              <p class="text-sm opacity-75">{p.desc}</p>
              <div class="mt-auto flex flex-wrap gap-1 pt-2">
                {p.tags.map(tag => (
                  <span class="bg-accent/10 text-accent rounded px-1.5 py-0.5 font-mono text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </Main>
  <Footer />
</Layout>
