---
// 프로젝트 목록 수정: src/data/projects.ts 만 편집하면 됩니다.
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { projects } from "@/data/projects";

const featured = projects.filter(p => p.featured);
const others   = projects.filter(p => !p.featured);
---

<Layout
  title={`Projects | ${config.site.title}`}
  description="leebeanbin의 포트폴리오 프로젝트 — AI, 백엔드, 풀스택 시스템"
>
  <Header />

  <main id="main-content" class="app-layout py-12 sm:py-16">

    <!-- 페이지 헤더 -->
    <div class="border-b border-border pb-8 mb-10">
      <p class="text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Portfolio</p>
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">Projects</h1>
      <p class="text-muted-foreground max-w-xl">
        직접 설계하고 만든 시스템들 — 코드, 구조, 그리고 만든 이유가 담겨 있습니다.
      </p>
    </div>

    <!-- Featured -->
    <section class="mb-14">
      <h2 class="text-xs font-mono uppercase tracking-widest text-muted-foreground mb-5">Featured</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map(p => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col border border-border rounded-xl p-5 gap-4 hover:border-accent transition-all hover:shadow-sm"
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="font-mono font-semibold text-base group-hover:text-accent transition-colors">
                  {p.name}
                </p>
                {p.status === "active" && (
                  <span class="inline-flex items-center gap-1 text-xs text-green-500 mt-0.5">
                    <span class="inline-block size-1.5 rounded-full bg-green-500"></span>
                    active
                  </span>
                )}
              </div>
              <svg class="size-4 shrink-0 mt-0.5 text-muted-foreground group-hover:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </div>

            <div class="flex-1">
              <p class="text-sm font-medium mb-1">{p.desc}</p>
              {p.longDesc && (
                <p class="text-xs text-muted-foreground leading-relaxed">{p.longDesc}</p>
              )}
            </div>

            <div class="flex flex-wrap gap-1.5">
              {p.tags.map(tag => (
                <span class="border border-border rounded-full px-2.5 py-0.5 font-mono text-xs group-hover:border-accent/50 transition-colors">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- More Projects — 리스트 형태 -->
    <section>
      <h2 class="text-xs font-mono uppercase tracking-widest text-muted-foreground mb-5">More</h2>
      <div class="divide-y divide-border">
        {others.map(p => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between gap-4 py-4 hover:text-accent transition-colors"
          >
            <div class="flex items-baseline gap-3 min-w-0">
              <span class="font-mono text-sm font-semibold shrink-0 group-hover:text-accent transition-colors">
                {p.name}
              </span>
              <span class="text-sm text-muted-foreground truncate hidden sm:block">
                {p.desc}
              </span>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <div class="hidden sm:flex flex-wrap gap-1 justify-end">
                {p.tags.slice(0, 2).map(tag => (
                  <span class="border border-border rounded px-2 py-0.5 font-mono text-xs">{tag}</span>
                ))}
              </div>
              <svg class="size-4 text-muted-foreground group-hover:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>
  <Footer />
</Layout>
