---
// 프로젝트 목록 수정:
//   깃허브 핀 자동 연동 (GITHUB_TOKEN 환경변수 필요)
//   폴백: src/data/projects.ts
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { projects as staticProjects } from "@/data/projects";
import { getGithubPinnedRepos, type GithubRepo } from "@/utils/getGithubPins";
import { TECH_COLORS } from "@/data/techColors";

// 빌드 시 GitHub 핀 레포 가져오기 (실패 시 null)
const pinned = await getGithubPinnedRepos();

// GitHub 핀 → 프로젝트 형식으로 변환
function repoToProject(r: GithubRepo) {
  const tags = r.repositoryTopics.nodes.map(n => n.topic.name);
  if (r.primaryLanguage?.name && !tags.includes(r.primaryLanguage.name)) {
    tags.unshift(r.primaryLanguage.name);
  }
  // projects.ts에 같은 이름이 있으면 longDesc 등 보완 정보 병합
  const local = staticProjects.find(p => p.name === r.name);
  return {
    name: r.name,
    url: r.url,
    desc: r.description ?? local?.desc ?? "",
    longDesc: local?.longDesc,
    tags: local?.tags ?? tags,
    featured: true,
    status: local?.status ?? "active" as const,
  };
}

const featured = pinned
  ? pinned.map(repoToProject)
  : staticProjects.filter(p => p.featured);

const others = staticProjects.filter(p =>
  !p.featured && !featured.some(f => f.name === p.name)
);
---

<Layout
  title={`Projects | ${config.site.title}`}
  description="leebeanbin 포트폴리오 — AI · Backend · Fullstack"
>
  <Header />
  <main id="main-content" class="app-layout py-12 sm:py-16">

    <div class="border-b border-border pb-8 mb-10">
      <p class="text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Portfolio</p>
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">Projects</h1>
      <p class="text-muted-foreground text-sm max-w-xl">
        <span class="lang-ko">직접 설계하고 만든 시스템들 — 코드, 구조, 그리고 만든 이유가 담겨 있습니다.</span>
        <span class="lang-en">Systems I've designed and built — code, structure, and the reason behind each one.</span>
      </p>
      {pinned && (
        <p class="text-xs text-muted-foreground mt-2 flex items-center gap-1">
          <svg class="size-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          <span class="lang-ko">GitHub 핀 레포 기준으로 자동 표시됩니다.</span>
          <span class="lang-en">Auto-synced from GitHub pinned repositories.</span>
        </p>
      )}
    </div>

    <!-- Featured / Pinned -->
    <section class="mb-14 reveal">
      <h2 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5">
        <span class="inline-block size-1.5 rounded-full bg-accent"></span>
        {pinned ? "Pinned" : "Featured"}
      </h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer"
             class="group flex flex-col border border-border rounded-xl p-5 gap-4 transition-colors duration-150 hover:border-accent/40"
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="font-mono font-semibold text-base">{p.name}</p>
                {p.status === "active" && (
                  <span class="inline-flex items-center gap-1 text-xs text-green-500 mt-0.5">
                    <span class="inline-block size-1.5 rounded-full bg-green-500 animate-pulse"></span>active
                  </span>
                )}
              </div>
              <svg class="size-4 shrink-0 mt-0.5 text-muted-foreground group-hover:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium mb-1">{p.desc}</p>
              {p.longDesc && <p class="text-xs text-muted-foreground leading-relaxed">{p.longDesc}</p>}
            </div>
            <div class="flex flex-wrap gap-1.5">
              {p.tags.map(tag => {
                const color = TECH_COLORS[tag];
                return (
                  <span
                    class="tech-chip border rounded-full px-2.5 py-0.5 font-mono text-xs transition-all cursor-default"
                    style={color ? `--chip-color:${color}` : ""}
                  >
                    {tag}
                  </span>
                );
              })}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- More -->
    {others.length > 0 && (
      <section class="reveal reveal-delay-1">
        <h2 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5">
          <span class="inline-block size-1.5 rounded-full bg-muted-foreground"></span>
          More
        </h2>
        <div class="divide-y divide-border">
          {others.map(p => (
            <a href={p.url} target="_blank" rel="noopener noreferrer"
               class="group flex items-center justify-between gap-4 py-4 transition-colors duration-150">
              <div class="flex items-baseline gap-3 min-w-0">
                <span class="font-mono text-sm font-semibold shrink-0">{p.name}</span>
                <span class="text-sm text-muted-foreground truncate hidden sm:block">{p.desc}</span>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <div class="flex gap-1">
                  {p.tags.slice(0, 2).map(tag => {
                    const color = TECH_COLORS[tag];
                    return (
                      <span
                        class="tech-chip border rounded px-2 py-0.5 font-mono text-xs transition-all"
                        style={color ? `--chip-color:${color}` : ""}
                      >
                        {tag}
                      </span>
                    );
                  })}
                </div>
                <svg class="size-4 text-muted-foreground group-hover:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </main>
  <Footer />
</Layout>

<style>
  .tech-chip {
    background: color-mix(in srgb, var(--chip-color, #6366F1) 10%, transparent);
    color: var(--chip-color, #6366F1);
    border-color: color-mix(in srgb, var(--chip-color, #6366F1) 30%, transparent);
  }
  .tech-chip:hover {
    background: color-mix(in srgb, var(--chip-color, #6366F1) 18%, transparent);
    border-color: var(--chip-color, #6366F1);
  }
</style>
