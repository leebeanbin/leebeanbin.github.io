---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import { siteContent } from "@/data/site";    // ← 콘텐츠는 여기서
import { projects } from "@/data/projects";   // ← 프로젝트도 여기서

const { posts: postsConfig } = config;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const homePath = getRelativeLocaleUrl(locale, "");

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts  = sortedPosts.filter(({ data }) => !data.featured);

const featuredProjects = projects.filter(p => p.featured);
const { hero, techStack } = siteContent;
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >

    <!-- ══ HERO ══════════════════════════════════════════════════════════════ -->
    <section class="border-border border-b py-16 sm:py-24">
      <p class="text-sm font-mono text-muted-foreground mb-3 tracking-widest uppercase">
        {hero.greeting}
      </p>

      <div class="flex items-end gap-4 flex-wrap mb-2">
        <h1 class="text-4xl sm:text-6xl font-bold tracking-tight leading-none">
          {hero.name}
        </h1>
        <span class="text-xl sm:text-2xl font-light text-muted-foreground pb-1">
          {hero.nameEn}
        </span>
        <a
          target="_blank"
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
          aria-label="RSS Feed"
          class="pb-1"
        >
          <IconRss width={18} height={18} class="stroke-muted-foreground hover:stroke-accent transition-colors" />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>

      <p class="text-accent font-mono text-sm sm:text-base mb-6 tracking-wide">
        {hero.role}
      </p>

      <p class="text-base sm:text-lg text-muted-foreground max-w-xl leading-relaxed mb-8">
        {hero.bio}
      </p>

      <!-- 기술 스택 칩 -->
      <div class="flex flex-wrap gap-2 mb-8">
        {techStack.map(tech => (
          <span class="border border-border rounded-full px-3 py-1 text-xs font-mono hover:border-accent hover:text-accent transition-colors cursor-default">
            {tech}
          </span>
        ))}
      </div>

      <!-- CTA 버튼 -->
      <div class="flex flex-wrap gap-4">
        <a
          href="/posts"
          class="inline-flex items-center gap-2 bg-foreground text-background px-5 py-2.5 rounded-lg text-sm font-medium hover:opacity-80 transition-opacity"
        >
          글 읽기 <IconArrowRight class="size-4" />
        </a>
        <a
          href="/projects"
          class="inline-flex items-center gap-2 border border-border px-5 py-2.5 rounded-lg text-sm font-medium hover:border-accent hover:text-accent transition-colors"
        >
          프로젝트 보기
        </a>
        <a
          href="/resume"
          class="inline-flex items-center gap-2 border border-border px-5 py-2.5 rounded-lg text-sm font-medium hover:border-accent hover:text-accent transition-colors"
        >
          이력서
        </a>
      </div>
    </section>

    <!-- ══ FEATURED PROJECTS (포스트 없을 때 먼저 보여줄 내용) ══════════════ -->
    <section class="border-border border-b py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-semibold tracking-wide">주요 프로젝트</h2>
        <LinkButton
          href="/projects"
          class="text-sm text-muted-foreground hover:text-accent transition-colors flex items-center gap-1"
        >
          전체 보기 <IconArrowRight class="size-3.5" />
        </LinkButton>
      </div>

      <div class="grid gap-3 sm:grid-cols-3">
        {featuredProjects.map(p => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group border border-border rounded-xl p-4 flex flex-col gap-3 hover:border-accent transition-colors"
          >
            <div class="flex items-start justify-between gap-2">
              <span class="font-mono text-sm font-semibold group-hover:text-accent transition-colors leading-snug">
                {p.name}
              </span>
              <svg class="size-3.5 shrink-0 mt-0.5 text-muted-foreground group-hover:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed flex-1">{p.desc}</p>
            <div class="flex flex-wrap gap-1">
              {p.tags.slice(0, 3).map(tag => (
                <span class="border border-border rounded px-1.5 py-0.5 font-mono text-xs">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ FEATURED POSTS ════════════════════════════════════════════════════ -->
    {featuredPosts.length > 0 && (
      <section class="border-border border-b py-12">
        <h2 class="text-lg font-semibold tracking-wide mb-4">{t.home.featured}</h2>
        <ul class="space-y-2">
          {featuredPosts.map(data => <Card variant="h3" {...data} />)}
        </ul>
      </section>
    )}

    <!-- ══ RECENT POSTS ══════════════════════════════════════════════════════ -->
    {recentPosts.length > 0 && (
      <section class="py-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold tracking-wide">{t.home.recentPosts}</h2>
          <LinkButton
            href={getRelativeLocaleUrl(locale, "posts")}
            class="text-sm text-muted-foreground hover:text-accent transition-colors flex items-center gap-1"
          >
            {t.home.allPosts} <IconArrowRight class="size-3.5" />
          </LinkButton>
        </div>
        <ul class="space-y-2">
          {recentPosts.slice(0, postsConfig.perIndex).map(data => (
            <Card variant="h3" {...data} />
          ))}
        </ul>
      </section>
    )}

    <!-- 포스트가 아직 없을 때 -->
    {sortedPosts.length === 0 && (
      <section class="py-16 text-center text-muted-foreground">
        <p class="text-lg mb-2">아직 작성된 글이 없습니다.</p>
        <p class="text-sm">
          <code class="bg-muted px-2 py-1 rounded text-xs">src/content/posts/</code>에 마크다운 파일을 추가하면 바로 표시됩니다.
        </p>
      </section>
    )}

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector<HTMLElement>("#main-content");
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (el?.dataset.layout) {
      sessionStorage.setItem("backUrl", el.dataset.homePath ?? baseRoot);
    }
  });
</script>
