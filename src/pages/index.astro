---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import { siteContent } from "@/data/site";

const { posts: postsConfig } = config;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const homePath = getRelativeLocaleUrl(locale, "");

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts   = sortedPosts.filter(({ data }) => !data.featured);

const { hero } = siteContent;
---

<Layout
  title={config.site.title}
  description={hero.bioEn ?? hero.bio}
>
  <Header />
  <main id="main-content" data-layout="index" data-home-path={homePath} class="app-layout">

    <!-- ══ INTRO ════════════════════════════════════════════════════════════ -->
    <section class="border-b border-border py-14 sm:py-20">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-8">
        <div class="animate-fade-in-up">
          <p class="text-xs font-mono text-muted-foreground tracking-widest uppercase mb-4">
            AI / Backend Engineer
          </p>
          <h1 class="font-bold tracking-tight mb-4 leading-tight" style="font-size: var(--text-fluid-hero)">
            <span class="lang-ko">{hero.name}</span>
            <span class="lang-en">{hero.nameEn}</span>
            <span class="block font-semibold text-muted-foreground mt-1" style="font-size: var(--text-fluid-2xl)">
              <span class="lang-ko">의 기술 블로그</span>
              <span class="lang-en">'s dev log</span>
            </span>
          </h1>
          <p class="text-base text-muted-foreground max-w-xl leading-relaxed">
            <span class="lang-ko">{hero.bio}</span>
            <span class="lang-en">{hero.bioEn}</span>
          </p>
        </div>

        <div class="flex flex-col gap-2 shrink-0 animate-fade-in-up animate-delay-2">
          <a href="/about"
             class="inline-flex items-center justify-center gap-2 border border-border rounded-lg px-4 py-2 text-sm font-medium hover:border-accent hover:text-accent transition-all duration-150 hover:-translate-y-0.5">
            <span class="lang-ko">소개 보기</span><span class="lang-en">About me</span>
            <span class="text-muted-foreground">→</span>
          </a>
          <a href="/projects"
             class="inline-flex items-center justify-center gap-2 bg-accent text-white rounded-lg px-4 py-2 text-sm font-medium hover:opacity-90 transition-all duration-150 hover:-translate-y-0.5">
            <span class="lang-ko">프로젝트</span><span class="lang-en">Projects</span>
            <span>↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ══ FEATURED POSTS ════════════════════════════════════════════════════ -->
    {featuredPosts.length > 0 && (
      <section class="border-b border-border py-10 animate-fade-in-up animate-delay-3">
        <h2 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-6">
          <span class="inline-block size-1.5 rounded-full bg-accent"></span>
          <span class="lang-ko">추천 포스트</span>
          <span class="lang-en">Featured</span>
        </h2>
        <ul class="space-y-2">
          {featuredPosts.map(data => <Card variant="h3" {...data} />)}
        </ul>
      </section>
    )}

    <!-- ══ RECENT POSTS ══════════════════════════════════════════════════════ -->
    <section class="py-10 animate-fade-in-up animate-delay-4">
      <div class="flex items-center justify-between mb-6">
        <h2 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted-foreground">
          <span class="inline-block size-1.5 rounded-full bg-muted-foreground"></span>
          <span class="lang-ko">최근 포스트</span>
          <span class="lang-en">Recent Posts</span>
        </h2>
        <div class="flex items-center gap-3">
          <a href="/rss.xml" title="RSS Feed"
             class="text-muted-foreground hover:text-accent transition-colors duration-150">
            <IconRss class="size-4" />
          </a>
          {sortedPosts.length > postsConfig.perIndex && (
            <LinkButton href={getRelativeLocaleUrl(locale, "posts")}
              class="text-xs text-muted-foreground hover:text-accent flex items-center gap-1 transition-colors duration-150">
              <span class="lang-ko">전체 보기</span>
              <span class="lang-en">All posts</span>
              <IconArrowRight class="size-3" />
            </LinkButton>
          )}
        </div>
      </div>

      {recentPosts.length > 0 ? (
        <ul class="space-y-2">
          {recentPosts.slice(0, postsConfig.perIndex).map(data => (
            <Card variant="h3" {...data} />
          ))}
        </ul>
      ) : sortedPosts.length > 0 ? (
        <p class="text-sm text-muted-foreground py-4">
          <span class="lang-ko">모든 포스트가 추천 포스트로 표시되어 있습니다. →</span>
          <span class="lang-en">All posts are featured. →</span>
          {" "}
          <a href="/posts" class="text-accent hover:underline">
            <span class="lang-ko">전체 보기</span>
            <span class="lang-en">View all</span>
          </a>
        </p>
      ) : (
        <div class="py-12 text-center border border-dashed border-border rounded-xl">
          <p class="text-muted-foreground text-sm mb-1">
            <span class="lang-ko">아직 작성된 글이 없습니다.</span>
            <span class="lang-en">No posts yet.</span>
          </p>
          <p class="text-xs text-muted-foreground">
            <code class="bg-muted px-1.5 py-0.5 rounded">src/content/posts/</code>
            <span class="lang-ko">에 마크다운 파일을 추가하면 바로 표시됩니다.</span>
            <span class="lang-en"> — add a markdown file to get started.</span>
          </p>
        </div>
      )}
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector<HTMLElement>("#main-content");
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (el?.dataset.layout) {
      sessionStorage.setItem("backUrl", el.dataset.homePath ?? baseRoot);
    }
  });
</script>
