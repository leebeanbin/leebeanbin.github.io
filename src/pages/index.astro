---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import { siteContent } from "@/data/site";

const { posts: postsConfig } = config;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const homePath = getRelativeLocaleUrl(locale, "");

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts   = sortedPosts.filter(({ data }) => !data.featured);

const { hero } = siteContent;
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" data-home-path={homePath} class="app-layout">

    <!-- ══ INTRO ════════════════════════════════════════════════════════════ -->
    <!-- 짧은 소개만 — 상세 프로필은 /about -->
    <section class="border-b border-border py-10 sm:py-14 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold mb-2">
          <span class="lang-ko">{hero.name}</span>
          <span class="lang-en">{hero.nameEn}</span>
          <span class="text-muted-foreground font-light text-lg sm:text-xl ml-2">
            <span class="lang-ko">의 기술 블로그</span>
            <span class="lang-en">'s dev log</span>
          </span>
        </h1>
        <p class="text-sm text-muted-foreground max-w-lg">
          <span class="lang-ko">{hero.bio}</span>
          <span class="lang-en">{hero.bioEn}</span>
        </p>
      </div>

      <div class="flex items-center gap-3 shrink-0">
        <a href="/about"
           class="border border-border rounded-lg px-3 py-1.5 text-xs font-medium hover:border-accent hover:text-accent transition-colors">
          <span class="lang-ko">소개</span><span class="lang-en">About</span>
        </a>
        <a href="/projects"
           class="border border-border rounded-lg px-3 py-1.5 text-xs font-medium hover:border-accent hover:text-accent transition-colors">
          <span class="lang-ko">프로젝트</span><span class="lang-en">Projects</span>
        </a>
        <a target="_blank" href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`} aria-label="RSS">
          <IconRss width={16} height={16} class="stroke-muted-foreground hover:stroke-accent transition-colors" />
        </a>
      </div>
    </section>

    <!-- ══ FEATURED POSTS ════════════════════════════════════════════════════ -->
    {featuredPosts.length > 0 && (
      <section class="border-b border-border py-10">
        <h2 class="text-xs font-mono uppercase tracking-widest text-muted-foreground mb-5">
          <span class="lang-ko">추천 포스트</span>
          <span class="lang-en">Featured</span>
        </h2>
        <ul class="space-y-2">
          {featuredPosts.map(data => <Card variant="h3" {...data} />)}
        </ul>
      </section>
    )}

    <!-- ══ RECENT POSTS ══════════════════════════════════════════════════════ -->
    <section class="py-10">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xs font-mono uppercase tracking-widest text-muted-foreground">
          <span class="lang-ko">최근 포스트</span>
          <span class="lang-en">Recent Posts</span>
        </h2>
        {sortedPosts.length > postsConfig.perIndex && (
          <LinkButton href={getRelativeLocaleUrl(locale, "posts")}
            class="text-xs text-muted-foreground hover:text-accent flex items-center gap-1">
            <span class="lang-ko">전체 보기</span>
            <span class="lang-en">All posts</span>
            <IconArrowRight class="size-3" />
          </LinkButton>
        )}
      </div>

      {recentPosts.length > 0 ? (
        <ul class="space-y-2">
          {recentPosts.slice(0, postsConfig.perIndex).map(data => (
            <Card variant="h3" {...data} />
          ))}
        </ul>
      ) : (
        <div class="py-12 text-center border border-dashed border-border rounded-xl">
          <p class="text-muted-foreground text-sm mb-1">
            <span class="lang-ko">아직 작성된 글이 없습니다.</span>
            <span class="lang-en">No posts yet.</span>
          </p>
          <p class="text-xs text-muted-foreground">
            <code class="bg-muted px-1.5 py-0.5 rounded">src/content/posts/</code>
            <span class="lang-ko">에 마크다운 파일을 추가하면 바로 표시됩니다.</span>
            <span class="lang-en"> — add a markdown file to get started.</span>
          </p>
        </div>
      )}
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector<HTMLElement>("#main-content");
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (el?.dataset.layout) {
      sessionStorage.setItem("backUrl", el.dataset.homePath ?? baseRoot);
    }
  });
</script>
