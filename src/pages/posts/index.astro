---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import IconEdit from "@/assets/icons/IconEdit.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { getPostCategory } from "@/utils/getPostCategory";
import config from "@/config";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const uniqueTags = getUniqueTags(posts);

// 카테고리(폴더)별 그룹화
type PostGroup = { category: string | null; posts: typeof sortedPosts };
const groupedPosts = sortedPosts.reduce<PostGroup[]>((acc, post) => {
  const cat = getPostCategory(post.id);
  const group = acc.find(g => g.category === cat);
  if (group) group.posts.push(post);
  else acc.push({ category: cat, posts: [post] });
  return acc;
}, []);
const hasCategories = groupedPosts.some(g => g.category !== null);
---

<Layout title={`포스트 | Posts | ${config.site.title}`}>
  <Header />

  <main id="main-content" class="app-layout pb-16 pt-8">

    <!-- 타이틀 -->
    <div class="border-b border-border pb-6 mb-8">
      <h1 class="text-2xl font-semibold sm:text-3xl mb-2">
        <span class="lang-ko">포스트</span>
        <span class="lang-en">Posts</span>
      </h1>
      <p class="text-sm text-muted-foreground italic">
        <span class="lang-ko">작성한 모든 글</span>
        <span class="lang-en">All posts</span>
        {sortedPosts.length > 0 && (
          <span id="post-count" class="ml-2 font-mono text-xs">
            (<span class="lang-ko">{sortedPosts.length}개</span>
            <span class="lang-en">{sortedPosts.length} posts</span>)
          </span>
        )}
      </p>
    </div>

    <!-- 태그 필터 칩 -->
    {uniqueTags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-2 items-center">
        <span class="text-xs font-mono text-muted-foreground mr-1 shrink-0">
          <span class="lang-ko">필터:</span>
          <span class="lang-en">Filter:</span>
        </span>
        <button
          class="tag-filter-btn active-filter"
          data-tag="__all__"
        >
          <span class="lang-ko">전체</span>
          <span class="lang-en">All</span>
          <span class="count">({sortedPosts.length})</span>
        </button>
        {uniqueTags.map(({ tag, tagName }) => {
          const count = sortedPosts.filter(p => p.data.tags?.includes(tag)).length;
          return (
            <button class="tag-filter-btn" data-tag={tag}>
              #{tagName}
              <span class="count">({count})</span>
            </button>
          );
        })}
      </div>
    )}

    <!-- 포스트 목록 -->
    {sortedPosts.length > 0 ? (
      <div id="posts-list" class="transition-opacity duration-150">
        {hasCategories ? (
          groupedPosts.map(({ category, posts }) => (
            <div class="post-group mb-6" data-category={category ?? "__root__"}>
              {category && (
                <div class="flex items-center gap-3 mt-8 mb-4 first:mt-0">
                  <span class="text-xs font-mono font-semibold uppercase tracking-widest text-muted-foreground">
                    {category}
                  </span>
                  <div class="flex-1 h-px bg-border"></div>
                  <span class="text-xs font-mono text-muted-foreground/50">{posts.length}</span>
                </div>
              )}
              <ul class="space-y-2">
                {posts.map(data => <Card variant="h2" {...data} />)}
              </ul>
            </div>
          ))
        ) : (
          <ul class="space-y-2">
            {sortedPosts.map(data => <Card variant="h2" {...data} />)}
          </ul>
        )}
      </div>
    ) : (
      <div class="py-20 text-center border border-dashed border-border rounded-xl">
        <IconEdit class="size-10 mx-auto text-muted-foreground mb-4" />
        <p class="font-semibold mb-1">
          <span class="lang-ko">아직 작성된 글이 없어요</span>
          <span class="lang-en">No posts yet</span>
        </p>
        <p class="text-xs text-muted-foreground mt-2">
          <code class="bg-muted px-1.5 py-0.5 rounded text-foreground">src/content/posts/</code>
          <span class="lang-ko"> 에 마크다운 파일을 추가하면 바로 표시됩니다.</span>
          <span class="lang-en"> — add a markdown file to get started.</span>
        </p>
      </div>
    )}

    <!-- 필터 결과 없음 -->
    <div id="no-results" class="hidden py-16 text-center border border-dashed border-border rounded-xl">
      <IconSearch class="size-8 mx-auto text-muted-foreground mb-3" />
      <p class="text-muted-foreground text-sm">
        <span class="lang-ko">이 태그의 포스트가 없습니다.</span>
        <span class="lang-en">No posts with this tag.</span>
      </p>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  .tag-filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    border: 1px solid var(--border);
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--muted-foreground);
    background: transparent;
    cursor: pointer;
    transition: border-color 150ms ease, color 150ms ease, background-color 150ms ease, transform 100ms ease;
    user-select: none;
  }
  .tag-filter-btn:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    color: var(--accent);
  }
  .tag-filter-btn:active {
    transform: scale(0.96);
  }
  .tag-filter-btn.active-filter {
    border-color: var(--accent);
    color: var(--accent);
    font-weight: 500;
  }
  .tag-filter-btn .count {
    color: var(--muted-foreground);
    opacity: 0.7;
  }
  .tag-filter-btn.active-filter .count {
    color: var(--accent);
    opacity: 0.7;
  }

  /* 카드 필터 애니메이션 */
  #posts-list {
    transition: opacity 120ms ease;
  }
</style>

<script>
  function initTagFilter() {
    const btns = document.querySelectorAll<HTMLButtonElement>(".tag-filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".post-card");
    const noResults = document.querySelector<HTMLElement>("#no-results");

    const params = new URLSearchParams(window.location.search);
    const initialTag = params.get("tag") ?? "__all__";

    function applyFilter(tag: string, pushHistory = true) {
      // 버튼 active 상태
      btns.forEach(btn => {
        btn.classList.toggle("active-filter", btn.dataset.tag === tag);
      });

      // URL param 업데이트 (뒤로가기 시 복원)
      if (pushHistory) {
        const next = new URLSearchParams(window.location.search);
        if (tag === "__all__") {
          next.delete("tag");
        } else {
          next.set("tag", tag);
        }
        const search = next.toString();
        history.replaceState(null, "", search ? `?${search}` : window.location.pathname);
      }

      const list = document.querySelector<HTMLElement>("#posts-list");
      if (list) list.style.opacity = "0";

      setTimeout(() => {
        let visible = 0;
        cards.forEach(card => {
          const tags: string[] = JSON.parse(card.dataset.tags ?? "[]");
          const show = tag === "__all__" || tags.includes(tag);
          card.style.display = show ? "" : "none";
          if (show) visible++;
        });

        if (noResults) {
          noResults.classList.toggle("hidden", visible > 0 || tag === "__all__");
        }

        if (list) list.style.opacity = "1";
      }, 100);
    }

    btns.forEach(btn => {
      btn.addEventListener("click", () => {
        applyFilter(btn.dataset.tag ?? "__all__");
      });
    });

    applyFilter(initialTag, false);
  }

  initTagFilter();
  document.addEventListener("astro:after-swap", initTagFilter);
</script>
