---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import IconEdit from "@/assets/icons/IconEdit.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { getPostCategory } from "@/utils/getPostCategory";
import config from "@/config";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const uniqueTags = getUniqueTags(posts);

// 카테고리(폴더)별 그룹화
type PostGroup = { category: string | null; posts: typeof sortedPosts };
const groupedPosts = sortedPosts.reduce<PostGroup[]>((acc, post) => {
  const cat = getPostCategory(post.id);
  const group = acc.find(g => g.category === cat);
  if (group) group.posts.push(post);
  else acc.push({ category: cat, posts: [post] });
  return acc;
}, []);
const hasCategories = groupedPosts.some(g => g.category !== null);
---

<Layout title={`포스트 | Posts | ${config.site.title}`}>
  <Header />

  <main id="main-content" class="app-layout pb-16 pt-8">

    <!-- 타이틀 -->
    <div class="border-b border-border pb-6 mb-8">
      <h1 class="text-2xl font-semibold sm:text-3xl mb-2">
        <span class="lang-ko">포스트</span>
        <span class="lang-en">Posts</span>
      </h1>
      <p class="text-sm text-muted-foreground italic">
        <span class="lang-ko">작성한 모든 글</span>
        <span class="lang-en">All posts</span>
        {sortedPosts.length > 0 && (
          <span id="post-count" class="ml-2 font-mono text-xs">
            (<span class="lang-ko">{sortedPosts.length}개</span>
            <span class="lang-en">{sortedPosts.length} posts</span>)
          </span>
        )}
      </p>
    </div>

    <!-- 태그 필터 탭 (슬라이딩 pill) -->
    {uniqueTags.length > 0 && (
      <div class="mb-8">
        <div class="tag-filter-row" role="tablist">
          <!-- 슬라이딩 pill indicator -->
          <div id="tag-indicator" aria-hidden="true"></div>

          <button
            class="tag-filter-btn active-filter"
            data-tag="__all__"
            role="tab"
            aria-selected="true"
          >
            <span class="lang-ko">전체</span>
            <span class="lang-en">All</span>
            <span class="count">{sortedPosts.length}</span>
          </button>
          {uniqueTags.map(({ tag, tagName }) => {
            const count = sortedPosts.filter(p => p.data.tags?.includes(tag)).length;
            return (
              <button class="tag-filter-btn" data-tag={tag} role="tab" aria-selected="false">
                #{tagName}
                <span class="count">{count}</span>
              </button>
            );
          })}
        </div>
      </div>
    )}

    <!-- 포스트 목록 -->
    {sortedPosts.length > 0 ? (
      <div id="posts-list" class="transition-opacity duration-150">
        {hasCategories ? (
          groupedPosts.map(({ category, posts }) => (
            <div class="post-group mb-6" data-category={category ?? "__root__"}>
              {category && (
                <div class="flex items-center gap-3 mt-8 mb-4 first:mt-0">
                  <span class="text-xs font-mono font-semibold uppercase tracking-widest text-muted-foreground">
                    {category}
                  </span>
                  <div class="flex-1 h-px bg-border"></div>
                  <span class="text-xs font-mono text-muted-foreground/50">{posts.length}</span>
                </div>
              )}
              <ul class="space-y-2">
                {posts.map(data => <Card variant="h2" {...data} />)}
              </ul>
            </div>
          ))
        ) : (
          <ul class="space-y-2">
            {sortedPosts.map(data => <Card variant="h2" {...data} />)}
          </ul>
        )}
      </div>
    ) : (
      <div class="py-20 text-center border border-dashed border-border rounded-xl">
        <IconEdit class="size-10 mx-auto text-muted-foreground mb-4" />
        <p class="font-semibold mb-1">
          <span class="lang-ko">아직 작성된 글이 없어요</span>
          <span class="lang-en">No posts yet</span>
        </p>
        <p class="text-xs text-muted-foreground mt-2">
          <code class="bg-muted px-1.5 py-0.5 rounded text-foreground">src/content/posts/</code>
          <span class="lang-ko"> 에 마크다운 파일을 추가하면 바로 표시됩니다.</span>
          <span class="lang-en"> — add a markdown file to get started.</span>
        </p>
      </div>
    )}

    <!-- 필터 결과 없음 -->
    <div id="no-results" class="hidden py-16 text-center border border-dashed border-border rounded-xl">
      <IconSearch class="size-8 mx-auto text-muted-foreground mb-3" />
      <p class="text-muted-foreground text-sm">
        <span class="lang-ko">이 태그의 포스트가 없습니다.</span>
        <span class="lang-en">No posts with this tag.</span>
      </p>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  /* ── 탭 필터 바 ─────────────────────────────────────────────────────────── */
  .tag-filter-row {
    position: relative;
    display: flex;
    gap: 4px;
    overflow-x: auto;
    flex-wrap: nowrap;
    scrollbar-width: none;
    padding: 3px;               /* pill이 잘리지 않도록 여백 */
    margin: -3px;
  }
  .tag-filter-row::-webkit-scrollbar { display: none; }

  /* 슬라이딩 pill */
  #tag-indicator {
    position: absolute;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--accent) 10%, var(--background));
    border: 1.5px solid var(--accent);
    pointer-events: none;
    opacity: 0;
    transition:
      left   220ms cubic-bezier(0.4, 0, 0.2, 1),
      top    220ms cubic-bezier(0.4, 0, 0.2, 1),
      width  220ms cubic-bezier(0.4, 0, 0.2, 1),
      height 220ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 80ms ease;
    z-index: 0;
  }

  .tag-filter-btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border-radius: 9999px;
    padding: 0.25rem 0.8rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--muted-foreground);
    background: transparent;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color 150ms ease;
    user-select: none;
    flex-shrink: 0;
  }
  .tag-filter-btn:hover { color: var(--foreground); }
  .tag-filter-btn.active-filter {
    color: var(--accent);
    font-weight: 500;
  }
  .tag-filter-btn .count {
    font-size: 0.65rem;
    color: var(--muted-foreground);
    opacity: 0.6;
  }
  .tag-filter-btn.active-filter .count {
    color: var(--accent);
    opacity: 0.6;
  }

  /* ── 카드 stagger 애니메이션 ─────────────────────────────────────────────── */
  @keyframes card-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .post-card.animating-in {
    animation: card-in 240ms cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--stagger, 0) * 35ms);
  }
</style>

<script>
  function initTagFilter() {
    const btns      = document.querySelectorAll<HTMLButtonElement>(".tag-filter-btn");
    const cards     = document.querySelectorAll<HTMLElement>(".post-card");
    const noResults = document.querySelector<HTMLElement>("#no-results");
    const indicator = document.getElementById("tag-indicator");
    const row       = document.querySelector<HTMLElement>(".tag-filter-row");

    if (!btns.length) return;

    const params     = new URLSearchParams(window.location.search);
    const initialTag = params.get("tag") ?? "__all__";

    // ── pill indicator 이동 ───────────────────────────────────────────────
    function movePill(btn: HTMLButtonElement, animate = true) {
      if (!indicator || !row) return;
      if (!animate) indicator.style.transition = "none";

      const bRect = btn.getBoundingClientRect();
      const rRect = row.getBoundingClientRect();
      indicator.style.left   = `${bRect.left - rRect.left + row.scrollLeft}px`;
      indicator.style.top    = `${bRect.top  - rRect.top  + row.scrollTop}px`;
      indicator.style.width  = `${bRect.width}px`;
      indicator.style.height = `${bRect.height}px`;
      indicator.style.opacity = "1";

      if (!animate) {
        // re-enable transition on next frame
        requestAnimationFrame(() => {
          if (indicator) indicator.style.transition = "";
        });
      }
    }

    // ── 필터 적용 ─────────────────────────────────────────────────────────
    function applyFilter(tag: string, pushHistory = true, animate = true) {
      // 버튼 active 상태 + aria
      btns.forEach(btn => {
        const active = btn.dataset.tag === tag;
        btn.classList.toggle("active-filter", active);
        btn.setAttribute("aria-selected", String(active));
        if (active) movePill(btn, animate);
      });

      // URL 업데이트
      if (pushHistory) {
        const next = new URLSearchParams(window.location.search);
        tag === "__all__" ? next.delete("tag") : next.set("tag", tag);
        const s = next.toString();
        history.replaceState(null, "", s ? `?${s}` : window.location.pathname);
      }

      // 카드 필터 + stagger 애니메이션
      cards.forEach(card => card.classList.remove("animating-in"));

      setTimeout(() => {
        let stagger = 0;
        cards.forEach(card => {
          const tags: string[] = JSON.parse(card.dataset.tags ?? "[]");
          const show = tag === "__all__" || tags.includes(tag);
          if (show) {
            card.style.display = "";
            card.style.setProperty("--stagger", String(stagger++));
            card.classList.add("animating-in");
          } else {
            card.style.display = "none";
          }
        });

        if (noResults) {
          noResults.classList.toggle("hidden", stagger > 0 || tag === "__all__");
        }
      }, animate ? 60 : 0);
    }

    btns.forEach(btn => {
      btn.addEventListener("click", () => applyFilter(btn.dataset.tag ?? "__all__"));
    });

    applyFilter(initialTag, false, false);
  }

  initTagFilter();
  document.addEventListener("astro:after-swap", initTagFilter);
</script>
