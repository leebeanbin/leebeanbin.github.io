---
import { useTranslations } from "@/i18n";
const t = useTranslations(Astro.currentLocale);
---

<!-- Mobile: fixed floating circle -->
<div
  id="btt-mobile"
  class="fixed bottom-6 right-5 z-50 md:hidden
         opacity-0 translate-y-4 transition-all duration-300 pointer-events-none"
  aria-hidden="true"
>
  <button
    data-button="back-to-top"
    aria-label={t.post.backToTop}
    class="relative size-12 rounded-full bg-background border border-border shadow-lg
           hover:border-accent hover:shadow-accent/20 hover:shadow-md
           active:scale-95 transition-all duration-150 flex items-center justify-center"
  >
    <!-- conic-gradient progress ring -->
    <span
      id="progress-ring"
      class="absolute inset-0 -z-10 block rounded-full"
    ></span>
    <svg class="size-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>
</div>

<!-- Desktop: sticky text button -->
<div
  id="btt-desktop"
  class="hidden md:flex sticky bottom-6 float-end me-0 mt-2
         opacity-0 translate-y-2 transition-all duration-300 pointer-events-none"
>
  <button
    data-button="back-to-top"
    aria-label={t.post.backToTop}
    class="group inline-flex items-center gap-1.5 rounded-lg border border-border bg-background/80 backdrop-blur-sm
           px-3 py-1.5 text-xs text-muted-foreground font-mono
           hover:border-accent hover:text-accent hover:bg-muted/40
           active:scale-[0.97] transition-all duration-150 shadow-sm"
  >
    <svg class="size-3 transition-transform duration-150 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
    {t.post.backToTop}
  </button>
</div>

<script is:inline data-astro-rerun>
  function backToTop() {
    const mobile = document.getElementById("btt-mobile");
    const desktop = document.getElementById("btt-desktop");
    const ring = document.getElementById("progress-ring");
    const btns = document.querySelectorAll("[data-button='back-to-top']");

    if (!mobile || !desktop) return;

    btns.forEach(btn => {
      btn.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    });

    function setVisible(el, visible) {
      el.style.opacity = visible ? "1" : "0";
      el.style.transform = visible ? "translateY(0)" : "";
      el.style.pointerEvents = visible ? "auto" : "none";
      if (el.id === "btt-mobile") el.setAttribute("aria-hidden", String(!visible));
    }

    let lastVisible = null;
    function onScroll() {
      const scrollTop = document.documentElement.scrollTop;
      const scrollTotal = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      if (scrollTotal <= 0) return;

      const pct = Math.min(Math.floor((scrollTop / scrollTotal) * 100), 100);
      const isVisible = pct > 20;

      if (ring) {
        ring.style.backgroundImage =
          `conic-gradient(var(--accent) ${pct}%, transparent ${pct}%)`;
        ring.style.padding = "2px";
        ring.style.borderRadius = "9999px";
      }

      if (isVisible !== lastVisible) {
        setVisible(mobile, isVisible);
        setVisible(desktop, isVisible);
        lastVisible = isVisible;
      }
    }

    let ticking = false;
    document.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => { onScroll(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });

    onScroll();
  }
  backToTop();
</script>
